{
  "manifest_version": 3,
  "name": "vimimin",
  "version": "0.3.0",
  "description": "Vimperator-like keyboard navigation for Firefox",
  "icons": {
    "48": "icons/enabled.svg"
  },
  "action": {
    "default_icon": "icons/enabled.svg",
    "default_title": "vimimin"
  },
  "permissions": ["tabs", "storage", "sessions", "bookmarks", "history"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "vimimin@example.com"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
