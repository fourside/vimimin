{
	"manifest_version": 3,
	"name": "vimimin",
	"version": "0.1.0",
	"description": "Vimperator-like keyboard navigation for Firefox",
	"permissions": ["tabs", "storage"],
	"background": {
		"scripts": ["background.js"],
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"run_at": "document_idle"
		}
	]
}
