{
	"compilerOptions": {
		"outDir": "dist",
		"module": "es2022",
		"target": "es2022",
		"types": [],
		"sourceMap": true,
		"declaration": false,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"moduleDetection": "force",
		"skipLibCheck": true,
		"moduleResolution": "bundler",
		"noEmit": true
	},
	"include": ["src"]
}
