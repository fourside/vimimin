{
  "name": "vimimin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "dev": "web-ext run --source-dir dist --firefox-profile dev-profile --keep-profile-changes",
    "check": "biome check .",
    "format": "biome check --write .",
    "lint": "biome lint .",
    "knip": "knip",
    "test": "vitest run",
    "test:e2e": "VIMIMIN_E2E=1 node build.mjs && npx playwright test",
    "test:watch": "vitest --watch",
    "typecheck": "tsc && tsc -p e2e",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.2",
    "esbuild": "^0.27.3",
    "knip": "^5.85.0",
    "playwright-webextext": "^0.0.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "web-ext": "^9.3.0"
  }
}
